# Convex Backend (still required until the migration is complete)
CONVEX_DEPLOYMENT=your-convex-deployment
NEXT_PUBLIC_CONVEX_URL=https://your-project.convex.cloud
CONVEX_SITE_URL=https://your-project.convex.site

# Receiver control plane (optional override during the Supabase migration)
# Example: http://localhost:3000/api/internal/receiver
RECEIVER_CONTROL_PLANE_URL=

# Supabase (required on the migration branch)
NEXT_PUBLIC_SUPABASE_URL=http://192.168.0.247:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=http://192.168.0.247:8000
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Application URLs
NEXT_PUBLIC_WEBHOOK_URL=https://your-receiver-domain.com
NEXT_PUBLIC_APP_URL=https://your-app-domain.com

# Polar.sh Billing (optional)
# Set to true for sandbox, false for production
POLAR_SANDBOX=true
POLAR_ACCESS_TOKEN=
POLAR_ORGANIZATION_ID=
POLAR_WEBHOOK_SECRET=
POLAR_PRO_PRODUCT_ID=
POLAR_PRO_PRICE_ID=

# SMTP (optional - for transactional emails)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Blog admin API (optional - required only if using the blog write API)
BLOG_API_SECRET=
