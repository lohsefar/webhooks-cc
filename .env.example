# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://your-supabase-host:8000
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=http://your-supabase-host:8000
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@your-supabase-host:5433/postgres

# Receiver (Rust) — use session pooler URL
DATABASE_URL=postgresql://postgres:password@your-supabase-host:5432/postgres

# Application URLs
NEXT_PUBLIC_WEBHOOK_URL=https://your-receiver-domain.com
NEXT_PUBLIC_APP_URL=https://your-app-domain.com

# Receiver <-> control plane auth
CAPTURE_SHARED_SECRET=your-shared-secret

# Polar.sh Billing (optional)
# Set to true for sandbox, false for production
POLAR_SANDBOX=true
POLAR_ACCESS_TOKEN=
POLAR_ORGANIZATION_ID=
POLAR_WEBHOOK_SECRET=
POLAR_PRO_PRODUCT_ID=
POLAR_PRO_PRICE_ID=

# SMTP (optional - for transactional emails)
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# Blog admin API (optional - required only if using the blog write API)
BLOG_API_SECRET=
